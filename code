from collections import deque
import random
import time
import statistics
import tracemalloc

graph = {}
matrix = []

def buat_graph(jumlah_node):

    global graph
    global matrix

    graph = {}

    for i in range(jumlah_node):
        graph[i] = []

    # Membuat graph acak
    for i in range(jumlah_node):

        banyak_jalan = random.randint(2,4)

        while len(graph[i]) < banyak_jalan:

            tujuan = random.randint(0,jumlah_node-1)

            if tujuan != i and tujuan not in graph[i]:

                graph[i].append(tujuan)

                if i not in graph[tujuan]:
                    graph[tujuan].append(i)

    # Membuat adjacency matrix
    matrix = [[0 for _ in range(jumlah_node)] for _ in range(jumlah_node)]

    for node in graph:
        for tetangga in graph[node]:
            matrix[node][tetangga] = 1

def tampil_list():

    print("===== ADJACENCY LIST =====")

    for node in graph:
        print(f"{node} -> {graph[node]}")

def tampil_matrix():

    print("===== ADJACENCY MATRIX =====")

    batas = min(20,len(matrix))

    print("    ",end="")

    for i in range(batas):
        print(f"{i:3}",end="")

    print()

    for i in range(batas):

        print(f"{i:3}",end=" ")

        for j in range(batas):

            print(matrix[i][j],end="  ")

        print()

    if len(matrix)>20:
        print("(Matrix dipotong, hanya 20x20 pertama yang ditampilkan)")

