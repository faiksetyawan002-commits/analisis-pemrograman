def bfs(start, goal):

    tracemalloc.start()
    waktu_awal = time.perf_counter()

    queue = deque([[start]])
    visited = set()

    node_diperiksa = 0

    while queue:

        path = queue.popleft()
        node = path[-1]

        node_diperiksa += 1

        if node == goal:

            waktu_akhir = time.perf_counter()
            current, peak = tracemalloc.get_traced_memory()
            tracemalloc.stop()

            return {
                "jalur": path,
                "panjang": len(path)-1,
                "node": node_diperiksa,
                "waktu": (waktu_akhir-waktu_awal)*1000,
                "memori": peak
            }

        if node not in visited:

            visited.add(node)

            for tetangga in graph[node]:

                if tetangga not in visited:

                    jalur_baru = list(path)
                    jalur_baru.append(tetangga)

                    queue.append(jalur_baru)

    tracemalloc.stop()
    return None

def dfs(start, goal):

    tracemalloc.start()
    waktu_awal = time.perf_counter()

    stack = [[start]]
    visited = set()

    node_diperiksa = 0

    while stack:

        path = stack.pop()
        node = path[-1]

        node_diperiksa += 1

        if node == goal:

            waktu_akhir = time.perf_counter()
            current, peak = tracemalloc.get_traced_memory()
            tracemalloc.stop()

            return {
                "jalur": path,
                "panjang": len(path)-1,
                "node": node_diperiksa,
                "waktu": (waktu_akhir-waktu_awal)*1000,
                "memori": peak
            }

        if node not in visited:

            visited.add(node)

            for tetangga in reversed(graph[node]):

                if tetangga not in visited:

                    jalur_baru = list(path)
                    jalur_baru.append(tetangga)

                    stack.append(jalur_baru)

    tracemalloc.stop()
    return None

def uji_algoritma(metode, jumlah_uji=30):

    waktu = []
    node = []
    memori = []

    for i in range(jumlah_uji):

        awal = random.randint(0, len(graph)-1)
        tujuan = random.randint(0, len(graph)-1)

        while tujuan == awal:
            tujuan = random.randint(0, len(graph)-1)

        if metode == "BFS":
            hasil = bfs(awal, tujuan)

        else:
            hasil = dfs(awal, tujuan)

        if hasil is not None:
            waktu.append(hasil["waktu"])
            node.append(hasil["node"])
            memori.append(hasil["memori"])

    return {

        "rerata_waktu": statistics.mean(waktu),

        "std": statistics.stdev(waktu) if len(waktu)>1 else 0,

        "rerata_node": statistics.mean(node),

        "rerata_memori": statistics.mean(memori)

    }

